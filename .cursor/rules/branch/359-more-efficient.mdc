### 2. パスマッチング時の seq アロケーション削減

#### 現状（問題）

`route.nim` の `match()` proc（line 256）は毎リクエストで `splitPathSegments(path)` を呼ぶ（line 266）。
`splitPathSegments` は `seq[string]` を生成し、`split("/")` がさらに substring を生成する。
これが `matchNode` の再帰ループに渡され、ループ全体で数個〜十数個のヒープアロケーションが発生する。

```nim
# route.nim:128-139 現状
func splitPathSegments(path:string):seq[string] =
  let pathWithoutQuery = path.split("?")[0]   # allocation
  ...
  return normalizedPath.split("/")            # allocation

# route.nim:256-277 現状
proc match(...):RouteMatch =
  ...
  let segments = splitPathSegments(path)      # 毎リクエスト allocation
  if not matchNode(matcher.root, httpMethod, segments, 0, capturedValues, routeEntry):
```

既にトライ木（`RouteMatcherNode`）による構造は実装済みであり、
ルート登録時のパース（`addMatcherEntry`）は起動時の一度だけなので問題ない。
マッチ時の `seq[string]` 生成のみが毎リクエストのオーバーヘッドとなっている。

#### 設計方針

`matchNode` のシグネチャを `segments: seq[string]` から `path: string, start: int` に変更し、
文字列を一度だけ走査してセグメント境界を `'/'` のインデックスで特定する。
substring を作らず、スライス比較（`path.toOpenArray(segStart, segEnd-1)`）でノードキーと照合する。

```nim
# 設計イメージ（route.nim）

# セグメントを都度 index で走査するバージョン
proc nextSegmentEnd(path: string, start: int): int =
  # start から次の '/' または末尾 を返す
  result = start
  while result < path.len and path[result] != '/':
    inc result

proc matchNodeByIndex(
  node: RouteMatcherNode,
  httpMethod: HttpMethod,
  path: string,         # 元の文字列（クエリ除き）
  start: int,           # 現在走査中のオフセット（先頭 '/' は除いた位置）
  capturedValues: var seq[string],
  routeEntry: var RouteEntry,
): bool =
  let segEnd = nextSegmentEnd(path, start)
  let atEnd = (start >= path.len)

  if atEnd:
    if node.entries.hasKey(httpMethod):
      routeEntry = node.entries[httpMethod]
      return true
    return false

  let segSlice = path.toOpenArray(start, segEnd - 1)

  # 静的マッチ：substring を作らずに比較
  for key, child in node.staticChildren:
    if key == segSlice:
      let nextStart = if segEnd < path.len: segEnd + 1 else: path.len
      if matchNodeByIndex(child, httpMethod, path, nextStart, capturedValues, routeEntry):
        return true
      break

  # 数値パラメータ
  if not node.intChild.isNil and isNumericSlice(path, start, segEnd):
    capturedValues.add(path[start..<segEnd])
    let nextStart = if segEnd < path.len: segEnd + 1 else: path.len
    if matchNodeByIndex(node.intChild, httpMethod, path, nextStart, capturedValues, routeEntry):
      return true
    capturedValues.setLen(capturedValues.len - 1)

  # 文字列パラメータ
  if not node.strChild.isNil and segEnd > start:
    capturedValues.add(path[start..<segEnd])
    let nextStart = if segEnd < path.len: segEnd + 1 else: path.len
    if matchNodeByIndex(node.strChild, httpMethod, path, nextStart, capturedValues, routeEntry):
      return true
    capturedValues.setLen(capturedValues.len - 1)

  return false

proc match(matcher: RouteMatcher, httpMethod: HttpMethod, path: string): RouteMatch =
  if matcher.isNil:
    return RouteMatch(route: nil, pathParams: nil)

  # クエリ文字列を除去（index 走査のみ、allocation なし）
  var pathEnd = path.len
  for i in 0..<path.len:
    if path[i] == '?':
      pathEnd = i
      break

  var routeEntry: RouteEntry
  var capturedValues = newSeq[string]()
  let start = if pathEnd > 0 and path[0] == '/': 1 else: 0

  if pathEnd <= start:
    # ルートパス "/"
    if not matchNodeByIndex(matcher.root, httpMethod, path, path.len, capturedValues, routeEntry):
      return RouteMatch(route: nil, pathParams: nil)
  else:
    let normalizedPath = path[0..<pathEnd]
    if not matchNodeByIndex(matcher.root, httpMethod, normalizedPath, start, capturedValues, routeEntry):
      return RouteMatch(route: nil, pathParams: nil)

  ...
```

#### 留意点

- `capturedValues.add(path[start..<segEnd])` はパラメータがある場合のみ発生する substring アロケーション（静的ルートでは完全ゼロ）。
- `staticChildren` のテーブルキー比較で `toOpenArray` が使えるかは `TableRef[string, ...]` の `==` 演算子次第。
  `string` への変換を一度行うほうが安全な場合は、静的ノード部分は現行ロジックを維持し、`split` だけ廃止する段階的アプローチも有効。
- `isNumericSlice(path, start, segEnd)` は既存の `isNumericSegment(segment)` を index 版に書き直したもの。

